{
  "name": "slack-xp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "typecheck": "tsc --noEmit",
    "setup:check": "bun scripts/setup-check.ts",
    "portal:verify": "bun scripts/setup-check.ts",
    "db:migrate": "drizzle-kit migrate",
    "portal:deploy": "bun scripts/portal-deploy.ts",
    "smoke:real": "bun scripts/real-service-smoke.ts",
    "format": "biome format --write",
    "test": "bun run test:unit && bun run test:server && bun run test:browser",
    "test:unit": "bun test tests/unit",
    "test:server": "bun test tests/server",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.22",
    "@neondatabase/serverless": "^1.1.0",
    "@portalsdk/core": "0.1.4",
    "@portalsdk/react": "0.1.2",
    "@tanstack/react-query": "^5.101.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "geist": "1.7.2",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@playwright/test": "^1.61.1",
    "@portalsdk/cli": "0.4.1",
    "@portalsdk/config": "0.1.4",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
