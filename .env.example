# DEPLOYMENT SCOPE
# local | test | preview | production. Vercel supplies VERCEL_ENV as a fallback.
APP_ENV=local
# mock | live (mock is rejected when APP_ENV or VERCEL_ENV is production)
SERVICE_MODE=mock
# The exact browser origin registered with Clerk and Portal. Required in live mode.
APP_ORIGIN=http://localhost:3000

# DEVELOPMENT SERVICE STACK
# Use one development Clerk, Portal, and Neon stack for local and preview scopes.
NEXT_PUBLIC_PORTAL_KEY=pk_your_development_publishable_key
# Server-only control-plane credential. Never prefix this value with NEXT_PUBLIC_.
PORTAL_SECRET=sk_your_development_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_development_publishable_key
CLERK_SECRET_KEY=sk_test_your_development_secret_key
# Signing secret for /api/webhooks/clerk (subscribe to user.created/user.updated).
CLERK_WEBHOOK_SECRET=whsec_your_development_webhook_secret
DATABASE_URL=postgresql://user:password@development-host/database?sslmode=require
# Shared only with Vercel Cron as an Authorization bearer token (16+ characters).
CRON_SECRET=replace_with_a_long_random_cron_secret

# PRODUCTION SERVICE STACK
# In Vercel's Production scope, set the same variable names to separate production
# Portal and Neon resources plus Clerk pk_live_/sk_live_ keys. Never reuse this
# development stack in production.

# OPTIONAL SERVER-ONLY SETTINGS
# Comma- or whitespace-separated exact Clerk user IDs with Operator access.
OPERATOR_CLERK_USER_IDS=user_your_operator

# DEPLOYMENT REGION
# Vercel Function placement is configured in vercel.json, not through a secret.
# Change its single regions entry to the region nearest the production Neon database.
