NEXT_PUBLIC_PORTAL_KEY=pk_your_publishable_key
# Server-only control-plane credential. Never prefix this value with NEXT_PUBLIC_.
PORTAL_SECRET=sk_your_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
# Signing secret for /api/webhooks/clerk (subscribe to user.created/user.updated)
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret
# Optional comma- or whitespace-separated Clerk user IDs with Operator access
OPERATOR_CLERK_USER_IDS=user_your_operator
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# local | test | preview | production
APP_ENV=local
# mock | live (mock is rejected when APP_ENV or VERCEL_ENV is production)
SERVICE_MODE=mock
